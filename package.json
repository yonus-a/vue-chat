{
  "name": "@yonus_amire01/chat",
  "version": "2.2.0",
  "type": "module",
  "description": "Reusable Vue 3 chat dashboard component extracted from the Behayand frontend.",
  "license": "UNLICENSED",
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/chat.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.typecheck.json",
    "dev": "vite build --watch",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "yarn build && vite --config demo/vite.dist.config.ts"
  },
  "peerDependencies": {
    "@vueuse/core": "^11.0.0 || ^12.0.0 || ^13.0.0 || ^14.0.0",
    "pinia": "^2.0.0 || ^3.0.0",
    "vue": "^3.5.0",
    "vue-i18n": "^9.0.0 || ^10.0.0 || ^11.0.0"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@phosphor-icons/vue": "^2.2.1",
    "@tanstack/vue-virtual": "^3.13.24",
    "emoji-mart": "^5.6.0",
    "nanoid": "^6.0.0",
    "signature_pad": "^5.1.3",
    "simple-peer": "^9.11.1",
    "vue-advanced-cropper": "^2.8.9",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vueuse/core": "^14.2.1",
    "motion-v": "^2.3.0",
    "pinia": "^2.3.0",
    "typescript": "^5.7.0",
    "unplugin-auto-import": "^0.18.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vue": "^3.5.31",
    "vue-i18n": "^11.4.5",
    "vue-tsc": "^2.2.0"
  }
}
